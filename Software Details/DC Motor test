from machine import Pin
from time import sleep_ms

ENA = Pin(15, Pin.OUT, value=0)
IN1 = Pin(13, Pin.OUT, value=0)
IN2 = Pin(14, Pin.OUT, value=0)

print("All LOW for 2s — measure ENA, IN1, IN2 with multimeter, should read ~0V")
sleep_ms(2000)

print("ENA HIGH — measure GPIO15, should read ~3.3V")
ENA.value(1)
sleep_ms(3000)
ENA.value(0)

print("IN1 HIGH — measure GPIO13, should read ~3.3V")
IN1.value(1)
sleep_ms(3000)
IN1.value(0)

print("IN2 HIGH — measure GPIO14, should read ~3.3V")
IN2.value(1)
sleep_ms(3000)
IN2.value(0)

print("ALL HIGH (motor should spin now)")
IN1.value(1)
IN2.value(0)
ENA.value(1)
sleep_ms(3000)

ENA.value(0)
IN1.value(0)
print("Done")

